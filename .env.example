# RIN environment template.
# RIN 环境变量模板。
# Do not store API keys in source control.
# 不要把 API Key 存入源码版本控制。
#
# Copy this file to .env and fill in real values.
# 复制此文件为 .env 并填写真实值。

RIN_OWNER_ID=local-owner
RIN_DEVICE_ID=local-device
RIN_DATA_DIR=.rin-data

# ── API Chat Provider (OpenAI-compatible) ──────────────────────────
# Governance: external-API-only chat.  RIN does not use a local model for chat.
# 治理要求：仅限外部 API 对话。RIN 不使用本地模型进行对话。

# Provider identifier.  Currently only openai-compatible is supported.
# 提供者标识。目前仅支持 openai-compatible。
RIN_CHAT_PROVIDER=openai-compatible

# DeepSeek official base URL.  Also works with any OpenAI-compatible endpoint.
# DeepSeek 官方 base URL。也兼容任意 OpenAI-compatible 端点。
RIN_API_CHAT_BASE_URL=https://api.deepseek.com

# Model identifier.  deepseek-v4-flash is the current recommended default.
# 模型标识。deepseek-v4-flash 是当前推荐的默认模型。
RIN_API_CHAT_MODEL=deepseek-v4-flash

# API key.  Required.  Keep real keys in untracked .env only.
# API Key。必填。真实 Key 只能放在未跟踪的 .env 中。
RIN_API_CHAT_KEY=

# Thinking mode for DeepSeek models.  Valid values: disabled, enabled, or unset.
# deepseek-v4-flash is used in non-thinking mode by default.
# DeepSeek 模型的思考模式。有效值：disabled、enabled 或不设置。
# deepseek-v4-flash 默认以非思考模式运行。
RIN_API_CHAT_THINKING=disabled

# ── Generation Parameters ──────────────────────────────────────────
# 生成参数

RIN_API_CHAT_TIMEOUT_MS=180000
RIN_API_CHAT_TEMPERATURE=0.5
RIN_API_CHAT_MAX_TOKENS=1024
RIN_API_CHAT_TOP_P=0.9

# ── Token Cost Estimates (CNY) ─────────────────────────────────────
# These are local estimates for UI cost display — not provider billing truth.
# 以下为 UI 成本显示的本地估算值——并非提供商的实际计费标准。

RIN_COST_INPUT_PER_1K_TOKENS_CNY=0.001
RIN_COST_OUTPUT_PER_1K_TOKENS_CNY=0.002
RIN_COST_CURRENCY=CNY

# ── Optional ───────────────────────────────────────────────────────
# 可选

# Explicit live external provider smoke.  Leave empty unless intentionally testing.
# 显式外部 provider smoke。只有明确测试时才设置。
RIN_EXTERNAL_MODEL_SMOKE=

# Optional Agent State Bundle import target.
# 可选 Agent State Bundle 导入目标。
RIN_BUNDLE_PATH=
RIN_IMPORT_DATA_DIR=.rin-imported-data
