# RIN environment template.
# RIN 环境变量模板。
# Do not store API keys in source control.
# 不要把 API Key 存入源码版本控制。

RIN_OWNER_ID=local-owner
RIN_DEVICE_ID=local-device
RIN_DATA_DIR=.rin-data

# Optional model adapter selection.
# 可选模型 adapter 选择。
RIN_MODEL_ADAPTER=rin-mock-local

# Ollama local adapter placeholders. Ollama does not need an API key.
# Ollama 本地 adapter 占位值。Ollama 不需要 API Key。
RIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
RIN_OLLAMA_MODEL=qwen3:4b

# OpenAI-compatible adapter placeholders. Keep real keys in untracked .env only.
# OpenAI-compatible adapter 占位值。真实 Key 只能放在未跟踪的 .env 中。
RIN_OPENAI_COMPATIBLE_BASE_URL=
RIN_OPENAI_COMPATIBLE_MODEL=
RIN_OPENAI_COMPATIBLE_API_KEY=

# Optional Agent State Bundle import target.
# 可选 Agent State Bundle 导入目标。
RIN_BUNDLE_PATH=
RIN_IMPORT_DATA_DIR=.rin-imported-data
