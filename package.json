{
  "name": "rin",
  "version": "0.0.0",
  "private": true,
  "description": "RIN local-first single-owner personal agent system. RIN 是本地优先、单一所有者的个人智能体系统。",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "rin:init": "tsx src/cli/initData.ts",
    "rin:inspect": "tsx src/cli/inspectData.ts",
    "rin:export": "tsx src/cli/exportBundle.ts",
    "rin:tool": "tsx src/cli/runTool.ts",
    "rin:console": "npm run build && tsx src/server/localConsoleServer.ts",
    "rin:console:server": "tsx src/server/localConsoleServer.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
