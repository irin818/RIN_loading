{
  "name": "rin",
  "version": "0.0.0",
  "private": true,
  "description": "RIN local-first single-owner personal agent system. RIN 是本地优先、单一所有者的个人智能体系统。",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "rin:check": "npm run typecheck && npm test && npm run lint && npm run build && npm run rin:readiness && npm run rin:memory-eval",
    "live2d:assets": "tsx scripts/live2d/generate-rin-assets.ts",
    "live2d:verify-runtime": "tsx scripts/live2d/verify-rin-runtime-package.ts",
    "live2d:source": "npm run live2d:assets && npm run live2d:verify-runtime && npm run live2d:source-psd && npm run live2d:verify-source-psd",
    "live2d:source-psd": "tsx scripts/live2d/generate-rin-source-psd.ts",
    "live2d:verify-source-psd": "tsx scripts/live2d/verify-rin-source-psd.ts",
    "rin:init": "tsx src/cli/initData.ts",
    "rin:inspect": "tsx src/cli/inspectData.ts",
    "rin:export": "tsx src/cli/exportBundle.ts",
    "rin:import": "tsx src/cli/importBundle.ts",
    "rin:readiness": "tsx src/cli/readiness.ts",
    "rin:memory-eval": "tsx src/cli/memoryEval.ts",
    "rin:semantic-eval": "tsx src/cli/semanticEval.ts",
    "rin:tool": "tsx src/cli/runTool.ts",
    "rin:console": "npm run build && tsx src/server/localConsoleServer.ts",
    "rin:console:server": "tsx src/server/localConsoleServer.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ag-psd": "^30.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
